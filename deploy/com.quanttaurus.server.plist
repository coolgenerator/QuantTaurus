<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.quanttaurus.server</string>
    <key>ProgramArguments</key>
    <array>
        <string>__QUANTTAURUS_ROOT__/engine/target/release/server</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__QUANTTAURUS_ROOT__/engine</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/qt-server.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/qt-server.log</string>
</dict>
</plist>
