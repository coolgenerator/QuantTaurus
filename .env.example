# QuantTaurus runtime configuration.
# Copy selected variables into your shell, launchd plist, or process manager.

# Core server
QT_DATA_DIR=data
QT_AUTOSWEEP_HOURS=24
QT_AUTORETRAIN_HOURS=6
QT_AUTORETRAIN_SYMBOL=BTCUSDT
QT_AUTORETRAIN_INTERVAL=4h
QT_AUTORETRAIN_DAYS=730

# Paper trading and portfolio risk
QT_MAX_DD=0.15
QT_INTRADAY_MINUTES=30
QT_INTRADAY_MIN_DELTA=0.10
QT_STOCK_LONG_ONLY=1
QT_GROSS_CAP=1.0
QT_VOL_TARGET=0.15
QT_TA_MOD=0

# Stock cost model overrides
QT_STOCK_FEE=0.00002
QT_STOCK_SLIPPAGE=0.0003

# Python bridge / sidecars
QT_API=http://localhost:8787
QT_OPT_CLOSE_DTE=7
QT_OPT_TP=1.00
QT_OPT_SL=-0.50
QT_OPT_IV_WIDE=60
